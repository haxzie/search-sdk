{
  "name": "websearch-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "A unified web search SDK to plug into AI agents — pluggable providers, framework-agnostic tools.",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --filter \"./packages/**\" typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
