{
  "name": "websearch-sdk",
  "version": "0.0.0",
  "private": true,
  "description": "A unified web search SDK to plug into AI agents — pluggable providers, framework-agnostic tools.",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=./packages/*",
    "build:web": "turbo run build --filter=@websearch-sdk/web",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@websearch-sdk/web",
    "dev:packages": "turbo run dev --filter=./packages/*",
    "test": "turbo run test",
    "test:watch": "vitest",
    "typecheck": "turbo run typecheck",
    "clean": "pnpm -r exec rm -rf dist .next out coverage .turbo node_modules && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "turbo": "^2.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
