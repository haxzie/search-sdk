{
  "name": "@search-sdk/exa",
  "version": "0.0.0",
  "description": "Exa provider for @search-sdk — neural web search + contents.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@search-sdk/core": "workspace:*",
    "zod": "^3.24.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
