{
  "name": "@websearch-sdk/ai-sdk",
  "version": "0.0.0",
  "description": "Vercel AI SDK adapter for @websearch-sdk — returns web_search / web_scrape tools.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@websearch-sdk/core": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "ai": "^5.0.0",
    "zod": "^3.24.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
