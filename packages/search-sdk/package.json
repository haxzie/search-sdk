{
  "name": "search-sdk",
  "version": "0.0.1",
  "description": "Unified, provider-agnostic web search SDK for AI agents. Alias package that re-exports @search-sdk/core.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@search-sdk/core": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "ai": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
